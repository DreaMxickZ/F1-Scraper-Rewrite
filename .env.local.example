# Supabase — ใช้ project เดิม
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # ใช้ฝั่ง server เท่านั้น (insert draft)

# Groq
GROQ_API_KEY=

# Optional: เปลี่ยน model ได้ เช่น llama-3.1-8b-instant (เร็วกว่า, token ประหยัดกว่า)
GROQ_MODEL=llama-3.3-70b-versatile

# ชื่อ table ใน Supabase (ตรงกับที่มีอยู่)
SUPABASE_TABLE=news_v2

# ── Scraping services (optional — สำหรับเว็บที่ JS-render) ──
# Jina AI Reader — ฟรี ไม่ต้อง key (เปิดใช้งานเสมอ)
JINA_ENABLED=true

# Browserless.io — free 6hr/month → https://browserless.io
BROWSERLESS_TOKEN=

# ScrapingBee — free 1000 credits → https://scrapingbee.com
SCRAPINGBEE_KEY=
